{
  "name": "@cyca/fkill-zig",
  "version": "9.0.0",
  "description": "Zig reimplementation of fkill-cli for macOS.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "os": [
    "darwin"
  ],
  "bin": {
    "fkill": "./bin/fkill"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "bin/fkill",
    "src",
    "build.zig",
    "build.zig.zon",
    "README.md"
  ],
  "scripts": {
    "pnpm:devPreinstall": "node ./scripts/setup-zig.mjs",
    "build": "node ./scripts/zig.mjs build -Doptimize=ReleaseFast",
    "dev": "node ./scripts/zig.mjs build",
    "test": "node ./scripts/zig.mjs build test",
    "prepack": "pnpm run build && mkdir -p bin && cp zig-out/bin/fkill bin/fkill && chmod 755 bin/fkill",
    "pack:dry": "pnpm run prepack && npm pack --dry-run --ignore-scripts",
    "publish:dry": "pnpm publish --dry-run --no-git-checks"
  },
  "engines": {
    "node": ">=18"
  }
}
